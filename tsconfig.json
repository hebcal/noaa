{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023", "esnext.temporal", "esnext.intl", "esnext.date"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"]
}
